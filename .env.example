# Copy this file to .env and fill in your values.
# Run with the npm scripts (they already pass --env-file=.env).

APPLICANTS=2
TARGET_FROM=2026-06-10
TARGET_TO=2026-07-07

# Respectful polling. Lower numbers = faster detection but higher ban risk.
# Slots can be very short-lived (cancellations), so 60s catches more of them than 90s.
POLL_INTERVAL_MS=60000
POLL_JITTER_MS=20000

# Keep a visible browser window (needed for "avisar y dejar listo").
HEADLESS=false
SOUND=true

# WhatsApp message (free) + phone call (paid) via CallMeBot. Setup in README.md.
# phone = country code + number, NO '+'  (Colombia example: 573001112233)
WHATSAPP_PHONE=
CALLMEBOT_APIKEY=

# Phone call alert. The same apikey usually works. ~$1-3/month after free trial calls.
CALL_ENABLED=true
# CALLMEBOT_CALL_APIKEY=   # only if your call apikey differs from the message one
